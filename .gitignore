# Local symlink to live HA /config (see scripts/setup_ha_live_link.*)
ha-live

# Ignore sensitive HA files
homeassistant/secrets.yaml
homeassistant/service_account.json

# HACS / runtime under www (never commit; live-only)
homeassistant/www/community/
homeassistant/www/tmp/
homeassistant/www/snapshots/
homeassistant/.storage/
homeassistant/*.db
homeassistant/*.log

# Ignore MikroTik private backups
infrastructure/configs/*.backup
infrastructure/configs/*.rsc