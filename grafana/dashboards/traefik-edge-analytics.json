  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "code": {
          "language": "markdown",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "## Traefik · Monitoring & analytics\nDefault **Bucket** is `traefik`. OTLP-style measurements use dotted names; request counters use `_field` **`count`** (confirmed via `schema.fieldKeys`). Set **Group traffic by tag** to **`entrypoint`** for `traefik.entrypoint.requests.total`, or **`service`** for `traefik.service.requests.total`. Use **`router`** only if that tag exists on the measurement.",
        "mode": "markdown"
      },
      "transparent": true,
      "type": "text",
      "title": ""
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 },
      "id": 2,
      "panels": [],
      "title": "Edge capacity & certificates",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 10000,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "semi-dark-blue", "value": null },
              { "color": "green", "value": 100 },
              { "color": "orange", "value": 2000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 4 },
      "id": 3,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"${open_connections_measurement}\")\n  |> filter(fn: (r) => r[\"_field\"] == \"gauge\" or r[\"_field\"] == \"counter\" or r[\"_field\"] == \"value\")\n  |> last()\n  |> group()\n  |> sum(column: \"_value\")",
          "refId": "A"
        }
      ],
      "title": "Open connections (sum)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "reqpm"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 4 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "percentChangeColorMode": "standard",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"${requests_measurement}\")\n  |> filter(fn: (r) => r[\"_field\"] == \"counter\" or r[\"_field\"] == \"value\" or r[\"_field\"] == \"count\")\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\", \"_start\", \"_stop\"])\n  |> group(columns: [\"_time\", \"_start\", \"_stop\"])\n  |> sum(column: \"_value\")\n  |> derivative(unit: 1s, nonNegative: true)\n  |> map(fn: (r) => ({ r with _value: r._value * 60.0 }))",
          "refId": "A"
        }
      ],
      "title": "HTTP throughput (req/min · total)",
      "type": "stat"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 4 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 7 },
              { "color": "yellow", "value": 14 },
              { "color": "green", "value": 30 }
            ]
          },
          "unit": "d"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cn" },
            "properties": [
              { "id": "custom.width", "value": 280 },
              { "id": "color", "value": { "fixedColor": "text", "mode": "fixed" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "sans" },
            "properties": [
              { "id": "custom.width", "value": 220 },
              { "id": "color", "value": { "fixedColor": "text", "mode": "fixed" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "serial" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "text", "mode": "fixed" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "days_remaining" },
            "properties": [{ "id": "displayName", "value": "Days left" }]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "days_remaining" }]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"${tls_not_after_measurement}\")\n  |> filter(fn: (r) => r[\"_field\"] == \"gauge\" or r[\"_field\"] == \"value\")\n  |> group(columns: [\"cn\", \"sans\", \"serial\"])\n  |> last()\n  |> map(fn: (r) => {\n      expirySec = float(v: r._value)\n      expiryNs = int(v: expirySec * 1000000000.0)\n      remainNs = expiryNs - int(v: uint(v: now()))\n      days = float(v: remainNs) / 86400000000000.0\n      return {r with _value: days}\n    })\n  |> sort(columns: [\"_value\"], desc: false)",
          "refId": "A"
        }
      ],
      "title": "TLS certificates · days remaining (one row per cert)",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "_time": true,
              "_start": true,
              "_stop": true,
              "_measurement": true,
              "_field": true,
              "result": true,
              "table": true
            },
            "renameByName": { "_value": "days_remaining" }
          }
        }
      ],
      "type": "table"
    },
