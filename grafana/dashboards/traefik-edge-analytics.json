        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "ok = from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"traefik.service.requests.total\")\n  |> filter(fn: (r) => r[\"_field\"] == \"counter\" or r[\"_field\"] == \"value\" or r[\"_field\"] == \"count\")\n  |> filter(fn: (r) => string(v: r[\"code\"]) =~ /^2/ or string(v: r[\"code\"]) =~ /^3/)\n  |> group()\n  |> sum(column: \"_value\")\n  |> set(key: \"_field\", value: \"ok\")\n\ntot = from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"traefik.service.requests.total\")\n  |> filter(fn: (r) => r[\"_field\"] == \"counter\" or r[\"_field\"] == \"value\" or r[\"_field\"] == \"count\")\n  |> filter(fn: (r) => string(v: r[\"code\"]) =~ /^[0-9]+$/)\n  |> group()\n  |> sum(column: \"_value\")\n  |> set(key: \"_field\", value: \"tot\")\n\nunion(tables: [ok, tot])\n  |> pivot(rowKey: [\"_start\", \"_stop\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => {\n      t = if exists r.tot then float(v: r.tot) else 0.0\n      k = if exists r.ok then float(v: r.ok) else 0.0\n      return {_time: r._start, _start: r._start, _stop: r._stop, _value: if t > 0.0 then 100.0 * k / t else 100.0}\n    })",
          "refId": "A"
        }
      ],
